# Frontend API origin. Leave empty in dev since Vite proxies /api → http://localhost:5000.
# In production set this to your deployed API origin, e.g. https://api.corehives.com
VITE_API_URL=

# Backend configuration
DATABASE_URL="mysql://root@localhost:3306/corehives"
ADMIN_TOKEN="your-secret-admin-token-here"
ADMIN_USERNAME="corehivesadmin"
ADMIN_PASSWORD="password"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
JWT_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# Email configuration
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
CONTACT_FROM_EMAIL="CoreHives Contact <no-reply@corehives.com>"
CONTACT_RECEIVER_EMAIL="connect@corehives.com"
